{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "commonjs",
    "lib":             ["ES2022"],
    "outDir":          "dist",
    "rootDir":         "src",
    "strict":          true,
    "declaration":     true,
    "sourceMap":       true,
    "esModuleInterop": true,
    "skipLibCheck":    true
  },
  "include": ["src"],
  "types": ["jest"],
  "exclude": ["node_modules", "dist"]
}
